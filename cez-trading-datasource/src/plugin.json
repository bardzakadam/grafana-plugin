{
  "type": "datasource",
  "name": "CEZ Trading",
  "id": "adambardzak-ceztrading-datasource",
  "info": {
    "description": "Data source plugin for CEZ Trading energy market charting API with OAuth2 authentication",
    "author": {
      "name": "Adam Bardzak",
      "url": "https://github.com/bardzakadam"
    },
    "keywords": ["energy", "trading", "cez", "intraday"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "version": "1.0.0",
    "updated": "2026-03-12",
    "links": [
      {
        "name": "GitHub",
        "url": "https://github.com/bardzakadam/grafana-plugin"
      }
    ],
    "screenshots": []
  },
  "dependencies": {
    "grafanaDependency": ">=10.0.0",
    "grafanaVersion": "10.0.0",
    "plugins": []
  },
  "routes": [
    {
      "path": "api",
      "url": "{{ .JsonData.apiUrl }}",
      "headers": [
        {
          "name": "Content-Type",
          "content": "application/json"
        }
      ],
      "tokenAuth": {
        "url": "{{ .JsonData.tokenUrl }}",
        "params": {
          "grant_type": "client_credentials",
          "client_id": "{{ .SecureJsonData.consumerKey }}",
          "client_secret": "{{ .SecureJsonData.consumerSecret }}"
        }
      }
    }
  ]
}
